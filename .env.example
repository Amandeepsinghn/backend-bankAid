# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-here

# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ZeptoMail (email OTP)
ZEPTOMAIL_API_KEY=your-zeptomail-api-key
ZEPTOMAIL_FROM_EMAIL=noreply@yourdomain.com
ZEPTOMAIL_FROM_NAME=Unfreeze
# ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

SENTRY_DSN=
